{
  "name": "md-editor-desktop",
  "version": "7.0.0",
  "private": true,
  "description": "Neutralinojs desktop port of MD-Editor",
  "scripts": {
    "setup": "node setup-binaries.js && node download-vendor.js",
    "postsetup": "node prepare.js",
    "predev": "npm run setup",
    "dev": "node run-neutralino.js run",
    "prebuild": "npm run setup",
    "build": "node run-neutralino.js build --embed-resources",
    "build:portable": "node run-neutralino.js build --release",
    "build:all": "npm run build && npm run build:portable"
  },
  "dependencies": {}
}
